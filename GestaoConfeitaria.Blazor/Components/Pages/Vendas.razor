@page "/vendas"
@using GestaoConfeitaria.Blazor.Services
@using GestaoConfeitaria.Shared.DTOs
@using GestaoConfeitariaWeb.Services
@rendermode InteractiveServer
@inject VendaService vendaServices
@inject NavigationManager Nav

<PageTitle>Vendas - Gestão Confeitaria</PageTitle>

<h3>Lista de Vendas</h3>

@if (vendasDto == null)
{
    <p><em>Carregando...</em></p>
}
else if (!vendasDto.Any())
{
    <p>Nenhuma venda registrada.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Data</th>
                <th>Valor Total</th>
                <th>Qtd. Bolos</th>
                <th>Pagamento</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var v in vendasDto)
            {
                <tr>
                    <td>@v.Data.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@v.ValorTotal.ToString("C2")</td>
                    <td>@v.QuantidadeBolos</td>
                    <td>@v.FormaPagamento</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<VendaDto> vendasDto = new();

    protected override async Task OnInitializedAsync()
    {
        var vendasDomain = await vendaServices.GetAllAsync();
        // Mapeamento manual simples
        vendasDto = vendasDomain.Select(v => new VendaDto
        {
            Id = v.Id,
            Data = v.Data,
            ValorTotal = v.ValorTotal,
            QuantidadeBolos = v.QuantidadeBolos,
            FormaPagamento = v.FormaPagamento,
            Usuario = v.Usuario
        }).ToList();
    }
}